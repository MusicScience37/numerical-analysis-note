{
  "latex-workshop.latex.tools": [
    {
      "name": "tectonic",
      "command": "tectonic",
      "args": ["--keep-intermediates", "--keep-logs", "--synctex", "%DOC%.tex"]
    },
    {
      "name": "tectonic-once",
      "command": "tectonic",
      "args": [
        "--keep-intermediates",
        "--keep-logs",
        "--synctex",
        "--reruns",
        "0",
        "%DOC%.tex"
      ]
    },
    {
      "name": "upmendex",
      "command": "upmendex",
      "args": ["-s", "jpbase", "-o", "%DOC%.ind", "%DOC%.idx"]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "tectonic-full",
      "tools": ["tectonic", "upmendex", "tectonic"]
    },
    {
      "name": "tectonic-quick",
      "tools": ["tectonic-once"]
    }
  ],
  "latex-workshop.latex.recipe.default": "tectonic-quick",
  "hadolint.cliOptions": ["--ignore", "DL3008", "--no-color"],
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "isort.args": ["--profile", "black"],
  "cSpell.enableFiletypes": ["bibtex", "shellscript", "toml"],
  "restructuredtext.linter.disabledLinters": ["rstcheck", "rst-lint"],
  "esbonio.server.enabled": false,
  "files.watcherExclude": {
    "**/.venv/**": true,
    "**/__pycache__/**": true,
    "**/.mypy_cache/**": true
  },
  "esbonio.sphinx.confDir": "",
  "restructuredtext.pythonRecommendation.disabled": true,
  "latex-workshop.latex.autoBuild.cleanAndRetry.enabled": false,
  "latex-workshop.formatting.latex": "latexindent",
  "python-envs.defaultEnvManager": "ms-python.python:poetry",
  "python-envs.defaultPackageManager": "ms-python.python:poetry"
}
